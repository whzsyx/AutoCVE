# =============================================
# AuditAI Frontend Docker жһ„е»ә
# =============================================
# дҪҝз”Ё Nginx жҸҗдҫӣйқҷжҖҒж–Үд»¶е’ҢеҸҚеҗ‘д»ЈзҗҶ (ж”ҜжҢҒ SSE жөҒејҸдј иҫ“)

FROM node:20-slim AS builder

WORKDIR /app

ARG VITE_ENABLE_CHECKMARX_SCAN=false

# еҪ»еә•жё…йҷӨд»ЈзҗҶи®ҫзҪ®
ENV http_proxy=""
ENV https_proxy=""
ENV HTTP_PROXY=""
ENV HTTPS_PROXY=""
ENV all_proxy=""
ENV ALL_PROXY=""
ENV no_proxy="*"
ENV NO_PROXY="*"

# й…ҚзҪ®еӣҪеҶ… npm й•ңеғҸжә?
RUN npm config set registry https://registry.npmmirror.com && \
    npm install -g pnpm && \
    pnpm config set registry https://registry.npmmirror.com

# еӨҚеҲ¶дҫқиө–ж–Үд»¶
COPY package.json pnpm-lock.yaml ./

# еўһеҠ зҪ‘з»ңи¶…ж—¶и®ҫзҪ®е’Ңе№¶еҸ‘ж•°йҷҗеҲ¶пјҢйҳІжӯ?ARM жһ¶жһ„жһ„е»әеҚЎжӯ»
RUN pnpm config set network-timeout 300000 && \
    pnpm config set fetch-retries 5 && \
    pnpm install --no-frozen-lockfile --network-concurrency 1

# еӨҚеҲ¶жәҗд»Јз ?
COPY . .

# рҹ”Ҙ жһ„е»әж—¶дҪҝз”ЁеҚ дҪҚз¬Ұ - е®һзҺ° Build Once Run Anywhere
ENV VITE_API_BASE_URL=__API_BASE_URL__
ENV VITE_ENABLE_CHECKMARX_SCAN=${VITE_ENABLE_CHECKMARX_SCAN}

# жһ„е»әз”ҹдә§зүҲжң¬
RUN pnpm build

# =============================================
# з”ҹдә§й•ңеғҸ - дҪҝз”Ё Nginx (ж”ҜжҢҒ SSE еҸҚеҗ‘д»ЈзҗҶ)
# =============================================
FROM nginx:alpine

# еӨҚеҲ¶жһ„е»әдә§зү©
COPY --from=builder /app/dist /usr/share/nginx/html

# еӨҚеҲ¶ Nginx й…ҚзҪ® (еҢ…еҗ« SSE еҸҚеҗ‘д»ЈзҗҶй…ҚзҪ®)
COPY nginx.conf /etc/nginx/conf.d/default.conf

# еӨҚеҲ¶еҗҜеҠЁи„ҡжң¬
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN sed -i 's/\r$//' /docker-entrypoint.sh && chmod +x /docker-entrypoint.sh

EXPOSE 80

ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["nginx", "-g", "daemon off;"]
